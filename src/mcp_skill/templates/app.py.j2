class {{ class_name }}:
    """
    Application for interacting with {{ base_name }} via MCP.
    Provides tools to {{ brief }}.
    """

{% if auth_type in ("bearer", "header") %}
    def __init__(self, url: str = "{{ server_url }}", auth=None) -> None:
        self.url = url
        self._token_storage = DiskStore(
            directory=Path.home() / ".mcp-skill" / "{{ skill_name }}" / "api-tokens"
        )
{% if auth_type == "bearer" %}
        self._auth = _BearerAuth(auth, self._token_storage)
{% else %}
        self._auth = _ApiKeyAuth(auth, self._token_storage)
{% endif %}
{% elif auth_type == "oauth" %}
    def __init__(self, url: str = "{{ server_url }}", auth=None) -> None:
        self.url = url
        self._token_storage = DiskStore(
            directory=Path.home() / ".mcp-skill" / "{{ skill_name }}" / "oauth-tokens"
        )
        self._oauth_auth = auth
{% else %}
    def __init__(self, url: str = "{{ server_url }}", auth=None) -> None:
        self.url = url
        if auth is not None:
            warnings.warn(
                "This server requires no authentication; the 'auth' argument will be ignored.",
                UserWarning,
                stacklevel=2,
            )
{% endif %}

{% if auth_type in ("bearer", "header") %}
    def _get_client(self) -> Client:
        return Client(self.url, auth=self._auth)
{% elif auth_type == "oauth" %}
    def _get_client(self) -> Client:
        oauth = self._oauth_auth or OAuth(token_storage=self._token_storage)
        return Client(self.url, auth=oauth)
{% else %}
    def _get_client(self) -> Client:
        return Client(self.url)
{% endif %}

